DATABASE_URL=
DATABASE_URL_DEV=
# Set DB_ENV=dev to route all DB calls to DATABASE_URL_DEV (Neon branch).
# Leave unset in production — Vercel only needs DATABASE_URL.
DB_ENV=
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
CRON_SECRET=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=
ADMIN_GITHUB_LOGINS=
# Set to "true" to switch from waitlist mode to live app CTAs on the landing page.
LAUNCH_MODE=
# Paid project boosts — set BOOST_ENABLED=true to show the Featured strip on /board.
BOOST_ENABLED=
# Per-project team chat (polling MVP; WebSocket upgrade planned for Go backend).
CHAT_ENABLED=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for a boost product in your Stripe dashboard.
STRIPE_BOOST_PRICE_ID=
