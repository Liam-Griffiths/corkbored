DATABASE_URL=
DATABASE_URL_DEV=
# Set DB_ENV=dev to route all DB calls to DATABASE_URL_DEV (Neon branch).
# Leave unset in production — Vercel only needs DATABASE_URL.
DB_ENV=
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
CRON_SECRET=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
# Email provider master switch. Unless set to "true" (and RESEND_API_KEY is set),
# all emails are logged instead of delivered.
EMAIL_ENABLED=
# Gates high-volume notification emails (application updates, announcement fan-out).
# Transactional emails like project invites ignore this and send whenever
# EMAIL_ENABLED is on. Keep off until you're comfortable with the volume.
NOTIFICATION_EMAILS_ENABLED=
NEXT_PUBLIC_APP_URL=
ADMIN_GITHUB_LOGINS=
# Set to "true" to switch from waitlist mode to live app CTAs on the landing page.
LAUNCH_MODE=
# Paid project boosts — set BOOST_ENABLED=true to show the Featured strip on /board.
BOOST_ENABLED=
# Real-time notification push via Go backend WebSocket (bell updates without page refresh).
# Simple mode (default/unset): notifications load on page refresh only.
LIVE_NOTIFICATIONS_ENABLED=
# Per-project team chat.
CHAT_ENABLED=
# Transport mode: "polling" (default, no extra infra) or "websocket" (requires Go backend).
CHAT_TRANSPORT=
# WebSocket backend URL — only used when CHAT_TRANSPORT=websocket.
CHAT_WS_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for a boost product in your Stripe dashboard.
STRIPE_BOOST_PRICE_ID=
